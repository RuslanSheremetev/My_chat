<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="30dp">
    <View android:layout_width="36dp" android:layout_height="4dp"
        android:background="#33ffffff" android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp" android:layout_marginBottom="16dp"/>
    <LinearLayout android:id="@+id/menuSearch" android:layout_width="match_parent"
        android:layout_height="56dp" android:gravity="center_vertical"
        android:paddingHorizontal="20dp" android:clickable="true"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:src="@drawable/ic_search" android:tint="#9ca3af"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Поиск в чате"
            android:textSize="16sp" android:textColor="#fff" android:layout_marginStart="16dp"/>
    </LinearLayout>
    <LinearLayout android:id="@+id/menuClear" android:layout_width="match_parent"
        android:layout_height="56dp" android:gravity="center_vertical"
        android:paddingHorizontal="20dp" android:clickable="true"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:src="@drawable/ic_trash" android:tint="#ff453a"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Очистить историю"
            android:textSize="16sp" android:textColor="#ff453a" android:layout_marginStart="16dp"/>
    </LinearLayout>
</LinearLayout>
