<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0c">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true">

        <TextView
            android:id="@+id/callAvatar"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:gravity="center"
            android:textSize="40sp"
            android:textColor="#fff"
            android:textStyle="bold"
            android:background="@drawable/bg_avatar_circle"
            android:text="A"/>

        <TextView
            android:id="@+id/callName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#fff"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:text="Имя"/>

        <TextView
            android:id="@+id/callStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#9ca3af"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:text="Соединение..."/>

        <TextView
            android:id="@+id/callTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#fff"
            android:textSize="28sp"
            android:layout_marginTop="30dp"
            android:text="00:00"
            android:visibility="gone"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="80dp">

        <ImageButton
            android:id="@+id/btnSpeaker"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_speaker"
            android:tint="#fff"
            android:background="@drawable/bg_call_btn"
            android:layout_marginEnd="20dp"/>

        <LinearLayout
            android:id="@+id/incomingActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/btnDecline"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/ic_call_end"
                android:tint="#fff"
                android:background="@drawable/bg_call_end"
                android:layout_marginEnd="40dp"/>

            <ImageButton
                android:id="@+id/btnAccept"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/ic_call_end"
                android:tint="#fff"
                android:background="@drawable/bg_call_accept"
                android:rotation="135"/>

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnEndCall"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_call_end"
            android:tint="#fff"
            android:background="@drawable/bg_call_end"
            android:layout_marginEnd="20dp"/>

        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_mic_call"
            android:tint="#fff"
            android:background="@drawable/bg_call_btn"/>

    </LinearLayout>

</RelativeLayout>
