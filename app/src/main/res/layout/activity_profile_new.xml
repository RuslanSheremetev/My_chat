<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Шапка с аватаркой -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="40dp"
        android:paddingBottom="10dp">

        <FrameLayout
            android:layout_width="110dp"
            android:layout_height="110dp">

            <TextView
                android:id="@+id/profileAvatarLarge"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:gravity="center"
                android:text="A"
                android:textColor="#fff"
                android:textSize="44sp"
                android:textStyle="bold"
                android:background="@drawable/bg_avatar_circle"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:id="@+id/avatarOverlay"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:background="@drawable/bg_avatar_circle"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <!-- Контент -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Личная информация -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ЛИЧНАЯ ИНФОРМАЦИЯ"
                android:textColor="#777777"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp" />

            <!-- Статус -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1e1e1e"
                android:padding="14dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Статус"
                    android:textColor="#888"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/profileStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Добавьте статус..."
                    android:text="В сети"
                    android:textColor="#fff"
                    android:textColorHint="#555"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@null"
                    android:inputType="text" />
            </LinearLayout>

            <!-- О себе -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1e1e1e"
                android:padding="14dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="О себе"
                    android:textColor="#888"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/profileBio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Расскажите о себе..."
                    android:text="Дизайнер интерфейсов"
                    android:textColor="#fff"
                    android:textColorHint="#555"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@null"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:gravity="top" />
            </LinearLayout>

            <!-- Кнопка Сохранить -->
            <Button
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Сохранить изменения"
                android:textColor="#fff"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_pink"
                android:padding="16dp"
                android:layout_marginTop="4dp"
                android:stateListAnimator="@null" />

            <!-- Уведомления -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="УВЕДОМЛЕНИЯ"
                android:textColor="#777777"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <!-- Тогглы -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1e1e1e"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_card">

                <include layout="@layout/item_toggle" />
                <include layout="@layout/item_toggle" />
                <include layout="@layout/item_toggle" />
            </LinearLayout>

            <!-- Хранилище -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ХРАНИЛИЩЕ"
                android:textColor="#777777"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <!-- Кэш -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1e1e1e"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Фото и файлы"
                        android:textColor="#fff"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="124 МБ"
                        android:textColor="#888"
                        android:textSize="14sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2c2c2c" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Голосовые сообщения"
                        android:textColor="#fff"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="38 МБ"
                        android:textColor="#888"
                        android:textSize="14sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2c2c2c" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Общий кэш"
                        android:textColor="#fff"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="162 МБ"
                        android:textColor="#888"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Кнопка очистить кэш -->
            <Button
                android:id="@+id/btnClearCache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Очистить кэш"
                android:textColor="#b0b0b0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_dark"
                android:padding="14dp"
                android:layout_marginTop="8dp"
                android:stateListAnimator="@null" />

            <!-- Выход -->
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="↪ Выйти из аккаунта"
                android:textColor="#b0b0b0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_dark"
                android:padding="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="20dp"
                android:stateListAnimator="@null" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
