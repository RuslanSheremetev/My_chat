<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#121212"
        android:padding="20dp"
        android:paddingBottom="40dp">

        <!-- Кнопка назад -->
        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:tint="#f06292"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Аватар -->
        <TextView
            android:id="@+id/profileAvatar"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:gravity="center"
            android:text="U"
            android:textSize="40sp"
            android:textColor="#fff"
            android:textStyle="bold"
            android:background="@drawable/bg_avatar_circle"
            android:layout_marginTop="20dp"
            android:layout_gravity="center_horizontal"/>

        <!-- Имя -->
        <TextView
            android:id="@+id/profileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User"
            android:textSize="22sp"
            android:textColor="#fff"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:layout_gravity="center_horizontal"/>

        <!-- Статус -->
        <TextView
            android:id="@+id/profileStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Статус"
            android:textSize="14sp"
            android:textColor="#8e8e93"
            android:layout_marginTop="4dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_status_edit"
            android:layout_gravity="center_horizontal"/>

        <!-- Редактирование статуса -->
        <LinearLayout
            android:id="@+id/editStatusSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/statusInput"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:hint="Введите статус..."
                android:textColor="#fff"
                android:textColorHint="#636366"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:radius="22dp"/>

            <Button
                android:id="@+id/saveStatusBtn"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Сохранить"
                android:textColor="#fff"
                android:background="@drawable/bg_btn_primary"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:radius="22dp"
                android:layout_marginStart="10dp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Тема с переключателем -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="#1c1c1e"
            android:layout_marginTop="20dp"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:text="Тема"
                    android:textSize="15sp"
                    android:textColor="#fff"/>

                <TextView
                    android:id="@+id/themeDesc"
                    android:text="Тёмная тема (активна)"
                    android:textSize="12sp"
                    android:textColor="#636366"/>
            </LinearLayout>

            <CheckBox
                android:id="@+id/themeSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"/>
        </LinearLayout>

        <!-- Кнопка выхода -->
        <Button
            android:id="@+id/logoutBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginTop="20dp"
            android:text="Выйти из аккаунта"
            android:textColor="#fff"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="#1c1c1e"
            android:radius="12dp"/>

    </LinearLayout>
</ScrollView>
