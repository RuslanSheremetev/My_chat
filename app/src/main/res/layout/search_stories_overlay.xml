<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/searchStoriesPanel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#121212"
    android:visibility="gone"
    android:paddingTop="12dp"
    android:paddingBottom="8dp">

    <!-- Строка поиска -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="10dp">

        <ImageButton
            android:id="@+id/searchBackBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="#b0b0b0"
            android:background="?attr/selectableItemBackground" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginStart="8dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_search_input">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:tint="#777" />

            <EditText
                android:id="@+id/searchStoriesInput"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="Поиск..."
                android:textColor="#fff"
                android:textColorHint="#777"
                android:textSize="15sp"
                android:inputType="text"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Лента историй -->
    <HorizontalScrollView
        android:id="@+id/storiesScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:id="@+id/storiesContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Моя история -->
            <LinearLayout
                android:id="@+id/storyMy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="16dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="66dp"
                    android:layout_height="66dp">
                    <View
                        android:layout_width="66dp"
                        android:layout_height="66dp"
                        android:background="@drawable/bg_story_ring_unseen" />
                    <TextView
                        android:id="@+id/storyMyAvatar"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:text="A"
                        android:textColor="#fff"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_avatar_circle_story" />
                    <View
                        android:id="@+id/storyMyAdd"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginBottom="-2dp"
                        android:layout_marginEnd="-2dp"
                        android:background="@drawable/bg_story_add" />
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Моё"
                    android:textColor="#fff"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- Истории будут добавляться программно -->
        </LinearLayout>
    </HorizontalScrollView>
</LinearLayout>
