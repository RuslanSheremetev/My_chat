<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@drawable/chat_item_ripple"
        android:gravity="center_vertical">
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">
            <TextView
                android:id="@+id/avatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:textSize="20sp"
                android:textColor="#fff"
                android:textStyle="bold"/>
            <View
                android:id="@+id/onlineDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_online_dot"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="2dp"
                android:layout_marginBottom="2dp"
                android:visibility="gone"/>
        </FrameLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">
            <TextView
                android:id="@+id/name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#fff"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/lastMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#8e8e93"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginStart="8dp">
            <TextView
                android:id="@+id/lastTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#8e8e93"
                android:paddingBottom="4dp"/>
            <ImageView
                android:id="@+id/msgStatusIcon"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_check_sent"
                android:tint="#8e8e93"
                android:visibility="gone"
                android:layout_gravity="end"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/lastImage"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#2c2c2e"
        android:layout_marginStart="72dp"/>
</LinearLayout>
