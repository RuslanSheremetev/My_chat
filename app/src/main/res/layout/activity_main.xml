<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Экран логина -->
    <LinearLayout
        android:id="@+id/loginLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MyChat"
            android:textSize="24sp"
            android:textColor="#f06292"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/loginUser"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:hint="Login"
            android:textColor="#fff"
            android:textColorHint="#636366"
            android:padding="14dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/loginPass"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:hint="Password"
            android:textColor="#fff"
            android:textColorHint="#636366"
            android:padding="14dp"
            android:layout_marginBottom="12dp"
            android:inputType="textPassword"/>

        <EditText
            android:id="@+id/serverUrl"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_input"
            android:hint="http://IP:8000"
            android:textColor="#fff"
            android:textColorHint="#636366"
            android:textSize="12sp"
            android:padding="10dp"
            android:layout_marginBottom="16dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Login"
            android:textColor="#fff"
            android:background="@drawable/bg_btn_primary"
            android:layout_marginBottom="8dp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Register"
            android:textColor="#fff"
            android:background="@drawable/bg_btn_secondary"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Главный контейнер -->
    <LinearLayout
        android:id="@+id/mainContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Список чатов -->
        <LinearLayout
            android:id="@+id/chatsScreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_chat_bubble"
                        android:tint="#8e8e93"
                        android:layout_marginEnd="10dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MyChat"
                        android:textSize="22sp"
                        android:textColor="#fff"
                        android:textStyle="bold"/>
                </LinearLayout>
                <ImageButton
                    android:id="@+id/btnCreate"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_user_plus"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="40dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp">

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input">

                    <EditText
                        android:id="@+id/searchInput"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Search..."
                        android:textColor="#fff"
                        android:textColorHint="#636366"
                        android:textSize="14sp"
                        android:drawableStart="@drawable/ic_search"
                        android:drawablePadding="10dp"
                        android:paddingStart="12dp"/>
                </RelativeLayout>

                <ImageButton
                    android:id="@+id/btnSearchClear"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_close"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#8e8e93"
                    android:visibility="gone"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/chatList"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>
        </LinearLayout>

        <!-- Экран профиля -->
        <ScrollView
            android:id="@+id/profileScreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/profileAvatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:gravity="center"
                    android:text="U"
                    android:textSize="36sp"
                    android:textColor="#fff"
                    android:background="@drawable/bg_avatar_circle"/>

                <TextView
                    android:id="@+id/profileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="20sp"
                    android:textColor="#fff"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:id="@+id/profileBio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="#8e8e93"
                    android:layout_marginTop="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                    <EditText
                        android:id="@+id/editBio"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input"
                        android:hint="Bio"
                        android:textColor="#fff"
                        android:textColorHint="#636366"
                        android:padding="10dp"/>

                    <Button
                        android:id="@+id/btnSaveProfile"
                        android:layout_width="80dp"
                        android:layout_height="44dp"
                        android:text="OK"
                        android:textColor="#fff"
                        android:background="@drawable/bg_btn_primary"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Нижняя навигация -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1c1c1e"
        android:orientation="horizontal"
        android:visibility="gone"
        android:paddingTop="4dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/navChats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chat_bubble"
                android:tint="#8e8e93"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Чаты"
                android:textSize="10sp"
                android:textColor="#8e8e93"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navFavorites"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_heart_simple"
                android:tint="#f06292"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Избранное"
                android:textSize="10sp"
                android:textColor="#f06292"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_user"
                android:tint="#8e8e93"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Профиль"
                android:textSize="10sp"
                android:textColor="#8e8e93"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Экран чата -->
    <LinearLayout
        android:id="@+id/chatLayout"
            android:background="@drawable/bg_chat_gradient"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#1c1c1e"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="6dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#f06292"/>

            <TextView
                android:id="@+id/chatAvatar"
                android:elevation="4dp"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="A"
                android:textSize="20sp"
                android:textColor="#fff"
                android:background="@drawable/bg_avatar_circle"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="10dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/chatTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name"
                    android:textColor="#fff"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/chatStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="online"
                    android:textColor="#34c759"
                    android:textSize="12sp"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnCall"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_phone"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#8e8e93"/>

            <ImageButton
                android:id="@+id/btnChatMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_dots"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#8e8e93"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/messagesList"
            android:background="@drawable/bg_chat_gradient"
            android:stackFromBottom="true"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1c1c1e"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="6dp"
            android:paddingBottom="16dp">

            <ImageButton
                android:id="@+id/btnAttach"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_plus_circle"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#8e8e93"/>

            <RelativeLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="44dp"
                android:background="@drawable/bg_input">
                <ImageButton
                        android:id="@+id/btnStickers"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_sticker"
                        android:background="@drawable/bg_clear_btn"
                        android:padding="4dp"/>
                    <EditText
                        android:id="@+id/msgInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="44dp"
                    android:background="@null"
                    android:hint="Message..."
                    android:textColor="#fff"
                    android:textColorHint="#636366"
                    android:paddingStart="40dp"
                    android:paddingEnd="40dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:maxLines="5"
                    android:gravity="top"/>
                <ImageButton
                    android:id="@+id/btnClearInput"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignEnd="@+id/msgInput"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_close"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#8e8e93"
                    android:visibility="gone"
                    android:scaleType="fitCenter"/>
            </RelativeLayout>

            <ImageButton
                android:id="@+id/btnMic"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_mic"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#8e8e93"
                android:visibility="visible"/>

            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_send"
                android:background="@drawable/bg_send_btn"
                android:tint="#fff"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
