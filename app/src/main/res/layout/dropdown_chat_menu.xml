<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dropdown_menu"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:elevation="8dp">

    <LinearLayout android:id="@+id/menuInfo"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:gravity="center_vertical" android:paddingStart="18dp" android:paddingEnd="18dp"
        android:orientation="horizontal" android:background="?attr/selectableItemBackground"
        android:clickable="true" android:focusable="true">
        <ImageView android:layout_width="22dp" android:layout_height="22dp"
            android:src="@drawable/ic_info" android:tint="#b0b0b0"/>
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:text="Информация" android:textColor="#fff" android:textSize="15sp"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/menuMute"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:gravity="center_vertical" android:paddingStart="18dp" android:paddingEnd="18dp"
        android:orientation="horizontal" android:background="?attr/selectableItemBackground"
        android:clickable="true" android:focusable="true">
        <ImageView android:layout_width="22dp" android:layout_height="22dp"
            android:src="@drawable/ic_mute" android:tint="#fbbf24"/>
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:text="Без звука" android:textColor="#fbbf24" android:textSize="15sp"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/menuSearch"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:gravity="center_vertical" android:paddingStart="18dp" android:paddingEnd="18dp"
        android:orientation="horizontal" android:background="?attr/selectableItemBackground"
        android:clickable="true" android:focusable="true">
        <ImageView android:layout_width="22dp" android:layout_height="22dp"
            android:src="@drawable/ic_search" android:tint="#b0b0b0"/>
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:text="Поиск" android:textColor="#fff" android:textSize="15sp"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/menuClear"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:gravity="center_vertical" android:paddingStart="18dp" android:paddingEnd="18dp"
        android:orientation="horizontal" android:background="?attr/selectableItemBackground"
        android:clickable="true" android:focusable="true">
        <ImageView android:layout_width="22dp" android:layout_height="22dp"
            android:src="@drawable/ic_delete" android:tint="#b0b0b0"/>
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:text="Очистить" android:textColor="#fff" android:textSize="15sp"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/menuBlock"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:gravity="center_vertical" android:paddingStart="18dp" android:paddingEnd="18dp"
        android:orientation="horizontal" android:background="?attr/selectableItemBackground"
        android:clickable="true" android:focusable="true">
        <ImageView android:layout_width="22dp" android:layout_height="22dp"
            android:src="@drawable/ic_block" android:tint="#ff453a"/>
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:text="Заблокировать" android:textColor="#ff453a" android:textSize="15sp"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

</LinearLayout>
