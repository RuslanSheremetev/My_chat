<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1c1c1e"
    android:padding="4dp"
    android:radius="12dp">

    <!-- Создать группу -->
    <LinearLayout
        android:id="@+id/menuGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp 16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:radius="8dp">

        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="👥"
            android:textSize="22sp"
            android:background="#2c2c2e"
            android:radius="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:text="Создать группу"
                android:textSize="16sp"
                android:textColor="#fff"/>

            <TextView
                android:text="Общайтесь с несколькими людьми"
                android:textSize="13sp"
                android:textColor="#8e8e93"/>
        </LinearLayout>

        <ImageView
            android:src="@drawable/ic_arrow"
            android:tint="#636366"
            android:layout_width="20dp"
            android:layout_height="20dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#2c2c2e"/>

    <!-- Создать ленту -->
    <LinearLayout
        android:id="@+id/menuFeed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp 16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:radius="8dp">

        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="📢"
            android:textSize="22sp"
            android:background="#2c2c2e"
            android:radius="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:text="Создать ленту"
                android:textSize="16sp"
                android:textColor="#fff"/>

            <TextView
                android:text="Публикуйте новости и обновления"
                android:textSize="13sp"
                android:textColor="#8e8e93"/>
        </LinearLayout>

        <ImageView
            android:src="@drawable/ic_arrow"
            android:tint="#636366"
            android:layout_width="20dp"
            android:layout_height="20dp"/>
    </LinearLayout>

</LinearLayout>
