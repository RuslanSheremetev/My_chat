<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_menu_create"
    android:padding="0dp">

    <LinearLayout
        android:id="@+id/menuGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="👥"
            android:textSize="20sp"
            android:background="@drawable/bg_attach_icon"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">
            <TextView
                android:text="Создать группу"
                android:textSize="16sp"
                android:textColor="#fff"
                android:textStyle="bold"/>
            <TextView
                android:text="Общайтесь с несколькими людьми"
                android:textSize="13sp"
                android:textColor="#8e8e93"/>
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#2c2c2e"/>

    <LinearLayout
        android:id="@+id/menuFeed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="📢"
            android:textSize="20sp"
            android:background="@drawable/bg_attach_icon"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">
            <TextView
                android:text="Создать ленту"
                android:textSize="16sp"
                android:textColor="#fff"
                android:textStyle="bold"/>
            <TextView
                android:text="Публикуйте новости и обновления"
                android:textSize="13sp"
                android:textColor="#8e8e93"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
